# E2E mode config — NOT secrets. These point the app at a mock Supabase host
# that the Playwright fixtures intercept (tests/fixtures/mockSupabase.js).
# Loaded by `vite --mode e2e` (see the dev:e2e npm script). Safe to commit.
VITE_SUPABASE_URL=https://mock.supabase.co
VITE_SUPABASE_ANON_KEY=mock-anon-key-not-a-secret
