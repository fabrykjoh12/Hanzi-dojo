# Placeholders only. Copy to .env (browser) / .env.script (server-side scripts)
# and fill in real values there - both are gitignored. Never commit a real key.

# ---------------------------------------------------------------------------
# .env - the browser app (Vite). These are baked into the client bundle, so
# only ever put values here that are safe to be public.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------------------------
# .env.script - server-side content and speech generation. NEVER prefix these
# with VITE_: that would ship them to every visitor's browser.
# ---------------------------------------------------------------------------
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Text-to-speech (see docs/TTS.md).
# The Azure key is a paid credential. It is read only by tts-generate.mjs and
# is never sent to, or referenced by, browser code.
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region          # lowercase, e.g. westeurope

TTS_DEFAULT_PROVIDER=azure                     # azure | mock
TTS_DEFAULT_LOCALE=zh-CN
TTS_FLASHCARD_VOICE=zh-CN-XiaoxiaoNeural
TTS_STORY_VOICE=zh-CN-XiaoxiaoMultilingualNeural
TTS_MALE_VOICE=zh-CN-YunxiNeural               # optional character voice

# Optional tuning. Sensible defaults apply when unset.
# TTS_TIMEOUT_MS=20000
# TTS_MAX_RETRIES=3
# TTS_CONCURRENCY=3                            # hard-capped at 8

# Opt-in only: set to 1 to allow the real-Azure integration check to run.
# It synthesizes a handful of short samples and costs a few cents.
# TTS_INTEGRATION=0

# Existing content pipeline (unrelated to TTS).
GOOGLE_TTS_KEY=your_google_tts_key
GEMINI_API_KEY=your_gemini_api_key
