# Test-mode config — NOT secrets. Vitest loads this (mode "test") so
# import.meta.env.VITE_SUPABASE_* are defined and src/supabase.js can build its
# client without throwing "Missing Supabase configuration" at import time.
# No network calls are made during unit tests. Safe to commit.
VITE_SUPABASE_URL=https://test.supabase.co
VITE_SUPABASE_ANON_KEY=test-anon-key-not-a-secret
